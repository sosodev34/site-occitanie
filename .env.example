# Stripe (server-only)
# Remplacer par la clé live lors du déploiement (ne pas committer de clé réelle).
STRIPE_SECRET_KEY=sk_live_xxx_replace_me

# Optional, helps build absolute URLs for redirects in development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_xxx_replace_me
EMAIL_FROM="Cœur d'Occitanie <onboarding@resend.dev>"

# Newsletter (optional): receive a notification email for each signup
NEWSLETTER_NOTIFY_TO=you@example.com
